            <ns3:atemp>25.0</ns3:atemp>
            <ns3:hr>180</ns3:hr>
            <ns3:cad>93</ns3:cad>
          </ns3:TrackPointExtension>
        </extensions>
      </trkpt>
    </trkseg>
  </trk>
</gpx>
